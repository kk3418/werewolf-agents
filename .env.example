# ── LLM Provider ──────────────────────────────────────────────────────────────
# 選擇要使用的 LLM 供應商（預設：anthropic）
LLM_PROVIDER=anthropic   # anthropic | openai | google | ollama

# 覆寫該供應商的預設模型（可選，留空使用預設）
# Anthropic 預設：claude-sonnet-4-6
# OpenAI 預設：gpt-4o
# Google 預設：gemini-2.0-flash
# Ollama 預設：llama3.1
LLM_MODEL=

# ── API Keys ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...        # LLM_PROVIDER=anthropic 時需要
OPENAI_API_KEY=sk-...               # LLM_PROVIDER=openai 時需要
GOOGLE_API_KEY=AIza...              # LLM_PROVIDER=google 時需要
# Ollama 不需要 API key，在本機跑

# Ollama 伺服器位址（預設：http://localhost:11434/v1）
OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Slack（Slack Bot 模式才需要）──────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# ── 遊戲設定（可選）──────────────────────────────────────────────────────────
PLAYER_NAMES=小明,小華,阿強,阿美,阿志,小玲   # 自訂玩家名稱（逗號分隔）
DELAY_MS=2000                                 # 每句話之間的間隔（ms）
GAME_CHANNEL_ID=                              # Slack 觀戰頻道 ID
